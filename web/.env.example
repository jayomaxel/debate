# For local development and local Docker, keep these empty so /api and /ws
# are served from the same host as the frontend.
#VITE_API_BASE_URL=
#VITE_WS_BASE_URL=
# Optional: override the Vite dev proxy backend when the API uses another port.
#VITE_DEV_API_PROXY_TARGET=http://localhost:7860
#VITE_DEV_WS_PROXY_TARGET=ws://localhost:7860
VITE_DEV_SERVER_PORT=5173
