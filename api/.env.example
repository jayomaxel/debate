# Backend environment template generated from api/config.py

ENVIRONMENT=development

APP_NAME=辩论教学系统
APP_VERSION=1.0.0
DEBUG=false

# 开发环境可配置本地数据库；生产环境必须显式配置 DATABASE_URL
DATABASE_URL=postgresql://pgvector:pgvector@localhost:5432/debate_system

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# 生产环境必须配置强 SECRET_KEY，且不能为默认值
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许的源，生产环境建议显式配置，如 https://your-domain.com
# 多个源使用逗号分隔，例如: https://app1.com,https://app2.com
# ALLOWED_ORIGINS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

ASR_API_KEY=
ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ASR_MODEL_NAME=qwen3-asr-flash-filetrans
ASR_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/audio/asr/transcription

TTS_API_KEY=
TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
TTS_MODEL_NAME=qwen3-tts-flash
TTS_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
TTS_DEFAULT_SPEED=1.5

COZE_API_KEY=
COZE_BASE_URL=https://api.coze.cn

DEBATE_AI_PROVIDER=llm

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
